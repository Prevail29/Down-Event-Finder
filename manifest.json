{
  "manifest_version": 3,
  "name": "Down-Event Finder",
  "version": "1.1",
  "description": "Devtools panel extension helping users find down-events (mousedown, pointerdown and touchstart) on any website.",
  "devtools_page": "devtools/devtools.html",
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon64.png",
    "128": "images/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'"
  },
  "permissions": [
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}