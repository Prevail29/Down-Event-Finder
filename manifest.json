{
  "manifest_version": 3,
  "name": "Down-Events Finder",
  "version": "0.1",
  "description": "An extension finding down-events on any website",
  "devtools_page": "./devtools/devtools.html",
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon64.png",
    "128": "images/icon128.png"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "file://*/*",
    "*://*/*"
  ]
}